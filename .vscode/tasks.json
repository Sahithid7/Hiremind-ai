{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "HireMind API: install dependencies",
      "type": "shell",
      "command": ".\\backend\\.venv\\Scripts\\python.exe",
      "args": ["-m", "pip", "install", "-r", "backend\\requirements.txt"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "HireMind API: run dev server",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": ["-m", "uvicorn", "app.main:app", "--host", "127.0.0.1", "--port", "8000", "--reload"],
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "HireMind Frontend: install dependencies",
      "type": "shell",
      "command": "npm.cmd",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "HireMind Frontend: run dev server",
      "type": "shell",
      "command": "npm.cmd",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
